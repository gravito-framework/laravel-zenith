{
    "name": "gravito/laravel-zenith",
    "description": "Deep Laravel introspection for Gravito Zenith - native queue monitoring, live logs, and HTTP metrics",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "monitoring",
        "queue",
        "logging",
        "gravito",
        "zenith"
    ],
    "authors": [
        {
            "name": "Gravito Framework",
            "email": "hello@gravito.dev"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/queue": "^10.0|^11.0",
        "illuminate/redis": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Gravito\\Zenith\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gravito\\Zenith\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gravito\\Zenith\\Laravel\\ZenithServiceProvider"
            ]
        }
    },
    "prefer-stable": true
}
